<!DOCTYPE html>
<html>
  <body style="margin:0;padding:0;background:#f4f4f5;font-family:Helvetica,Arial,sans-serif;color:#18181b;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5;padding:32px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;overflow:hidden;">
            <tr>
              <td style="padding:32px 40px;border-bottom:1px solid #e4e4e7;">
                <h1 style="margin:0;font-size:20px;">{{workspaceName}}</h1>
                <p style="margin:8px 0 0;color:#16a34a;font-size:14px;font-weight:bold;">Payment received</p>
              </td>
            </tr>
            <tr>
              <td style="padding:32px 40px;">
                <p style="margin:0 0 16px;font-size:14px;">Hi {{clientName}},</p>
                <p style="margin:0 0 24px;font-size:14px;">
                  Thank you - we have received your payment of
                  <strong>{{currency}} {{amountPaid}}</strong> for invoice
                  <strong>{{number}}</strong>. This invoice is now settled and no
                  further action is needed.
                </p>
                {{#if overpaidBy}}
                <p style="margin:0 0 24px;font-size:14px;background:#fef9c3;border:1px solid #fde047;border-radius:6px;padding:12px 16px;">
                  We received <strong>{{currency}} {{overpaidBy}}</strong> more than the
                  invoice total of {{currency}} {{total}}. The overpayment is credited to
                  your account - reach out if you would prefer a refund.
                </p>
                {{/if}}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="font-size:13px;">
                  <tr>
                    <td style="color:#71717a;padding:4px 0;">Invoice</td>
                    <td style="text-align:right;padding:4px 0;">{{number}}</td>
                  </tr>
                  <tr>
                    <td style="color:#71717a;padding:4px 0;">Issued</td>
                    <td style="text-align:right;padding:4px 0;">{{issueDate}}</td>
                  </tr>
                  <tr style="border-top:2px solid #e4e4e7;">
                    <td style="padding:8px 0;font-weight:bold;">Amount paid</td>
                    <td style="text-align:right;padding:8px 0;font-weight:bold;">{{currency}} {{amountPaid}}</td>
                  </tr>
                </table>
                {{#if notes}}
                <p style="margin:24px 0 0;font-size:13px;color:#71717a;">{{notes}}</p>
                {{/if}}
              </td>
            </tr>
            <tr>
              <td style="padding:24px 40px;background:#fafafa;border-top:1px solid #e4e4e7;">
                <p style="margin:0;font-size:12px;color:#a1a1aa;">
                  Sent by {{workspaceName}} via Foundry.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
