<!DOCTYPE html>
<html>
  <body style="margin:0;padding:0;background:#f4f4f5;font-family:Helvetica,Arial,sans-serif;color:#18181b;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5;padding:32px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;overflow:hidden;">
            <tr>
              <td style="padding:32px 40px;border-bottom:1px solid #e4e4e7;">
                <h1 style="margin:0;font-size:20px;">{{workspaceName}}</h1>
                <p style="margin:8px 0 0;color:#71717a;font-size:14px;">Quote {{number}}</p>
              </td>
            </tr>
            <tr>
              <td style="padding:32px 40px;">
                <p style="margin:0 0 16px;font-size:14px;">Hi {{clientName}},</p>
                <p style="margin:0 0 24px;font-size:14px;">
                  Please find quote <strong>{{number}}</strong> below. It was issued on
                  {{issueDate}} and is valid until <strong>{{validUntil}}</strong>.
                  A PDF copy is attached.
                </p>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="font-size:13px;border-collapse:collapse;">
                  <tr style="border-bottom:2px solid #e4e4e7;color:#71717a;text-align:left;">
                    <th style="padding:8px 0;">Description</th>
                    <th style="padding:8px 0;text-align:right;">Qty</th>
                    <th style="padding:8px 0;text-align:right;">Rate</th>
                    <th style="padding:8px 0;text-align:right;">Amount</th>
                  </tr>
                  {{#each items}}
                  <tr style="border-bottom:1px solid #f4f4f5;">
                    <td style="padding:8px 0;">{{this.description}}</td>
                    <td style="padding:8px 0;text-align:right;">{{this.quantity}}</td>
                    <td style="padding:8px 0;text-align:right;">{{../currency}} {{this.rate}}</td>
                    <td style="padding:8px 0;text-align:right;">{{../currency}} {{this.amount}}</td>
                  </tr>
                  {{/each}}
                </table>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="font-size:13px;margin-top:16px;">
                  <tr>
                    <td style="color:#71717a;padding:4px 0;">Subtotal</td>
                    <td style="text-align:right;padding:4px 0;">{{currency}} {{subtotal}}</td>
                  </tr>
                  <tr>
                    <td style="color:#71717a;padding:4px 0;">Tax ({{taxRate}}%)</td>
                    <td style="text-align:right;padding:4px 0;">{{currency}} {{tax}}</td>
                  </tr>
                  <tr style="border-top:2px solid #e4e4e7;">
                    <td style="padding:8px 0;font-weight:bold;">Estimated total</td>
                    <td style="text-align:right;padding:8px 0;font-weight:bold;">{{currency}} {{total}}</td>
                  </tr>
                </table>
                <p style="margin:24px 0 0;font-size:14px;">
                  Reply to this email to accept the quote or ask for changes.
                </p>
                {{#if notes}}
                <p style="margin:24px 0 0;font-size:13px;color:#71717a;">{{notes}}</p>
                {{/if}}
              </td>
            </tr>
            <tr>
              <td style="padding:24px 40px;background:#fafafa;border-top:1px solid #e4e4e7;">
                <p style="margin:0;font-size:12px;color:#a1a1aa;">
                  Sent by {{workspaceName}} via Foundry.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
