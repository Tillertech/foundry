generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  runtime                = "nodejs"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = ""
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  USD
  EUR
  GBP
  KES
}

enum ClientStatus {
  active
  lead
  archived
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
}

enum InvoiceStatus {
  draft
  sent
  viewed
  partially_paid
  paid
  overpaid
  overdue
  cancelled
}

enum QuoteStatus {
  draft
  sent
  accepted
  declined
  expired
}

enum PaymentMethod {
  card
  bank_transfer
  stripe
  paypal
  cash
  mobile_money
  other
}

enum ExpenseCategory {
  software
  travel
  meals
  office
  marketing
  other
}

enum DocumentType {
  contract
  nda
  receipt
  report
  other
}

enum ReconciliationKind {
  payment_applied
  payment_reversed
}

enum NotificationKind {
  invoice_sent
  invoice_paid
  invoice_reminder
  quote_sent
  document_shared
}

model User {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String      @unique
  name            String
  passwordHash    String
  otpSecret       String?
  emailVerifiedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  workspaces      Workspace[]
  notifications   Notification[]

  @@map("users")
}

/// In-app notification shown behind the header bell; created when an email
/// (invoice, quote, reminder, shared document) is successfully delivered.
model Notification {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind       NotificationKind @default(invoice_sent)
  title      String
  body       String
  /// Id of the entity the notification points at (invoice, quote or document).
  resourceId String?          @db.Uuid
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model Workspace {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String       @db.VarChar(500)
  /// Registered legal entity name, when it differs from the trading name.
  legalName          String?      @db.VarChar(500)
  slug               String       @db.VarChar(500)
  currency           Currency     @default(USD)
  city               String?      @db.VarChar(500)
  country            String?      @db.VarChar(500)
  email              String?      @db.VarChar(500)
  phone              String?      @db.VarChar(500)
  website            String?      @db.VarChar(500)
  address            String?      @db.VarChar(500)
  postCode           String?      @db.VarChar(500)
  taxCode            String?      @db.VarChar(500)
  invoicePrefix      String?
  quotePrefix        String?
  footerNote         String?
  /// Default tax rate (percent) applied to new invoices and quotes.
  taxRate            Decimal      @default(0) @db.Decimal(5, 2)
  paymentTerms       Int          @default(7)
  /// Storage key: local path in dev, S3 object key in prod.(logo)
  storageKey         String?
  status             ClientStatus @default(active)
  /// Invoice due-date reminder emails on/off for this workspace.
  remindersEnabled   Boolean      @default(false)
  /// How many days before the due date reminders start (also the re-send throttle).
  reminderDaysBefore Int          @default(3)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  ownerId String   @db.Uuid
  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  clients Client[]

  @@map("workspace")
}

model Client {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String
  company   String?
  currency  Currency     @default(USD)
  status    ClientStatus @default(active)
  phone     String?      @db.VarChar(250)
  taxId     String?
  address   String?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  projects  Project[]
  invoices  Invoice[]
  quotes    Quote[]
  payments  Payment[]
  documents Document[]

  @@map("clients")
}

model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  status      ProjectStatus @default(planning)
  budget      Decimal       @default(0) @db.Decimal(12, 2)
  hourlyRate  Decimal?      @db.Decimal(9, 2)
  startDate   DateTime
  endDate     DateTime?
  description String?

  clientId String @db.Uuid
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  invoices        Invoice[]
  expenses        Expense[]
  documents       Document[]
  reconciliations ReconciliationEntry[]

  @@index([clientId])
  @@map("projects")
}

model Invoice {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  number         String        @unique
  status         InvoiceStatus @default(draft)
  issueDate      DateTime
  dueDate        DateTime
  currency       Currency      @default(USD)
  taxRate        Decimal       @default(0) @db.Decimal(5, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  notes          String?
  /// Last time a due/overdue reminder email went out (reminder throttle).
  lastRemindedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  clientId  String   @db.Uuid
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  items           InvoiceItem[]
  payments        Payment[]
  reconciliations ReconciliationEntry[]

  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  rate        Decimal @default(0) @db.Decimal(12, 2)

  invoiceId String  @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Quote {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  number     String      @unique
  status     QuoteStatus @default(draft)
  issueDate  DateTime
  validUntil DateTime
  currency   Currency    @default(USD)
  taxRate    Decimal     @default(0) @db.Decimal(5, 2)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  clientId String @db.Uuid
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  items QuoteItem[]

  @@index([clientId])
  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  rate        Decimal @default(0) @db.Decimal(12, 2)

  quoteId String @db.Uuid
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

model Payment {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount    Decimal       @db.Decimal(12, 2)
  currency  Currency      @default(USD)
  method    PaymentMethod @default(bank_transfer)
  reference String?
  date      DateTime
  notes     String?
  createdAt DateTime      @default(now())

  clientId  String   @db.Uuid
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceId String?  @db.Uuid
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  reconciliations ReconciliationEntry[]

  @@index([clientId])
  @@map("payments")
}

/// Immutable ledger of how payments settle invoice and project balances.
/// An entry keeps both links so the same timeline is viewable from the
/// invoice, the project, or both.
model ReconciliationEntry {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind           ReconciliationKind @default(payment_applied)
  /// Payment amount applied (positive) or reversed (negative).
  amount         Decimal            @db.Decimal(12, 2)
  currency       Currency           @default(USD)
  /// Amount still owed on the invoice after this entry.
  invoiceBalance Decimal?           @db.Decimal(12, 2)
  /// Project budget remaining after this entry (budget - payments received).
  projectBalance Decimal?           @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime           @default(now())

  paymentId String?  @db.Uuid
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  invoiceId String?  @db.Uuid
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([projectId])
  @@map("reconciliation_entries")
}

model Expense {
  id       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendor   String
  category ExpenseCategory @default(other)
  amount   Decimal         @db.Decimal(12, 2)
  currency Currency        @default(USD)
  date     DateTime
  billable Boolean         @default(false)
  notes    String?

  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("expenses")
}

model Document {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  type       DocumentType @default(other)
  /// Storage key: local path in dev, S3 object key in prod.
  storageKey String
  size       Int          @default(0)
  mimeType   String?
  notes      String?
  uploadedAt DateTime     @default(now())

  clientId  String?  @db.Uuid
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@map("documents")
}
